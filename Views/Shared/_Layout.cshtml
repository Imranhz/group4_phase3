<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Group4Flight</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
@{
    var area = (string?)ViewContext.RouteData.Values["area"] ?? "user";
    var selectionCount = (int)(ViewBag.SelectionCount ?? 0);
}
<body class="@area.ToLowerInvariant()">
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-area="" asp-controller="Home" asp-action="Index">✈ Group4Flight</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto">
                    <li class="nav-item">
                        <a class="nav-link @(area == "" && ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Index">Search Flights</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(area == "" && ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && ViewContext.RouteData.Values["action"]?.ToString() == "Selections" ? "active" : "")" asp-area="" asp-controller="Home" asp-action="Selections">
                            My Selections
                            @if (selectionCount > 0)
                            {
                                <span class="badge bg-warning text-dark ms-1">@selectionCount</span>
                            }
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(area == "Airline" ? "active" : "")" asp-area="Airline" asp-controller="Home" asp-action="Index">Airline Portal</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    @if (TempData["Message"] != null)
    {
        <div class="container mt-2">
            <div class="alert alert-success alert-dismissible fade show" role="alert">
                @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        </div>
    }

    <main class="container my-4">
        @RenderBody()
    </main>

    <footer class="bg-light border-top py-3 mt-4">
        <div class="container text-center text-muted">
            <p class="mb-0">Contact us: <a href="mailto:support@group4flight.com">support@group4flight.com</a> &copy; @DateTime.Now.Year Group4Flight</p>
        </div>
    </footer>

    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/moment/moment.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/daterangepicker/daterangepicker.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
