@model Group4Flight.Models.Flight
@{
    ViewData["Title"] = "Flight Details";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow">
            <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
                <h4 class="mb-0">Flight Details</h4>
                <span class="badge bg-light text-primary fs-6">@Model.FlightCode</span>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <h6 class="text-muted mb-3">Route Information</h6>
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <div class="text-center">
                                    <div class="fs-4 fw-bold">@Model.From</div>
                                    <div class="text-muted small">Departure</div>
                                </div>
                                <div class="text-center text-primary">
                                    <span class="fs-4">✈</span>
                                </div>
                                <div class="text-center">
                                    <div class="fs-4 fw-bold">@Model.To</div>
                                    <div class="text-muted small">Arrival</div>
                                </div>
                            </div>
                            <hr />
                            <div class="row text-center">
                                <div class="col-6">
                                    <div class="fw-semibold">@Model.DepartureTime.ToString(@"hh\:mm")</div>
                                    <div class="text-muted small">Departs</div>
                                </div>
                                <div class="col-6">
                                    <div class="fw-semibold">@Model.ArrivalTime.ToString(@"hh\:mm")</div>
                                    <div class="text-muted small">Arrives</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="border rounded p-3 h-100">
                            <h6 class="text-muted mb-3">Flight Information</h6>
                            <table class="table table-sm table-borderless mb-0">
                                <tr>
                                    <td class="text-muted">Airline</td>
                                    <td class="fw-semibold">@(Model.Airline?.Name ?? "—")</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Date</td>
                                    <td class="fw-semibold">@Model.Date.ToString("dddd, MMMM dd, yyyy")</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Cabin Type</td>
                                    <td class="fw-semibold">@Model.CabinType</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Aircraft</td>
                                    <td class="fw-semibold">@Model.AircraftType</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Emission</td>
                                    <td class="fw-semibold">@Model.Emission kg CO₂</td>
                                </tr>
                                <tr>
                                    <td class="text-muted">Price</td>
                                    <td class="fw-bold text-success fs-5">$@Model.Price.ToString("0.00")</td>
                                </tr>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="card-footer d-flex gap-2 justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary">← Back to Results</a>
                <form asp-action="Select" method="post">
                    <input type="hidden" name="id" value="@Model.FlightId" />
                    <button type="submit" class="btn btn-success">Select This Flight</button>
                </form>
            </div>
        </div>
    </div>
</div>
