@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<nav class="navbar navbar-expand-lg navbar-dark bg-secondary mt-2">
    <div class="container">
        <a class="navbar-brand fw-bold" asp-area="Admin" asp-controller="Home" asp-action="Index">Admin Portal</a>
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#adminNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="adminNav">
            <ul class="navbar-nav me-auto">
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Index" ? "active" : "")"
                       asp-area="Admin" asp-controller="Home" asp-action="Index">
                        Dashboard
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Manage" ? "active" : "")"
                       asp-area="Admin" asp-controller="Home" asp-action="Manage">
                        Manage
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link @(ViewContext.RouteData.Values["action"]?.ToString() == "Rights" ? "active" : "")"
                       asp-area="Admin" asp-controller="Home" asp-action="Rights">
                        Rights & Obligations
                    </a>
                </li>
            </ul>
            <ul class="navbar-nav ms-auto">
                <li class="nav-item">
                    <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index">View Site</a>
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container mt-3">
    @RenderBody()
</div>
